{
  "name": "@fermi-ventures/launchkit-core",
  "version": "0.1.0",
  "description": "Core types, utilities, and patterns for LaunchKit applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./rbac": {
      "types": "./dist/rbac/index.d.ts",
      "import": "./dist/rbac/index.js"
    },
    "./urls": {
      "types": "./dist/urls/index.d.ts",
      "import": "./dist/urls/index.js"
    },
    "./scoring": {
      "types": "./dist/scoring/index.d.ts",
      "import": "./dist/scoring/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "next-auth": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "next-auth": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fermi-ventures/launchkit.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "keywords": [
    "launchkit",
    "core",
    "types",
    "utilities",
    "rbac",
    "nextjs"
  ]
}
