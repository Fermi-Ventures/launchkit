{
  "name": "@fermi-ventures/launchkit-design-system",
  "version": "0.1.0",
  "description": "Design system utilities for LaunchKit applications - color palettes, gradients, themes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    },
    "./palettes": {
      "types": "./dist/palettes.d.ts",
      "import": "./dist/palettes.js"
    },
    "./gradients": {
      "types": "./dist/gradients.d.ts",
      "import": "./dist/gradients.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@vitest/ui": "^2.1.8",
    "react": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fermi-ventures/launchkit.git",
    "directory": "packages/design-system"
  },
  "license": "MIT",
  "keywords": [
    "launchkit",
    "design-system",
    "theme",
    "color-palette",
    "gradients",
    "tailwind"
  ]
}
